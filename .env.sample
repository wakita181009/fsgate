# fsgate configuration — copy to `.env` and fill in.
# `.env` is gitignored; never commit real secrets.
# See README.md ("Configuration") and docs/design/auth.md for details.

# --- Required ---

# Absolute path to the directory served to Claude (must exist).
FSGATE_ROOT=/Users/you/Documents/Notes

# Public HTTPS origin — the Tailscale/tunnel hostname. Used as the WebAuthn RP,
# the token audience, and the base for advertised endpoints. MUST be https://.
# The passkey is bound to this hostname; keep it stable.
FSGATE_PUBLIC_ORIGIN=https://your-machine.tailnet-xxxx.ts.net

# Where credentials.json lives (passkeys, signing key, registered clients).
# Permissions are enforced to 0600.
FSGATE_STATE_DIR=/Users/you/.local/state/fsgate

# Recovery / enrollment-gate password. Required until at least one passkey is
# enrolled; thereafter it is the fallback login. Hashed (Argon2id) on first run.
# Generate a strong value, e.g. `openssl rand -base64 24`. FAIL-CLOSED if unset
# and no passkey is enrolled.
FSGATE_OAUTH_PASSWORD=change-me-use-a-strong-random-value

# --- Optional (defaults shown) ---

# `true`: the password can complete /authorize as a fallback. Set to `false`
# for passkey-only, once you've confirmed passkey login works from the iOS app.
# FSGATE_ALLOW_PASSWORD_AUTH=true

# HS256 secret for access tokens. If unset, a random key is generated and
# persisted to credentials.json on first run. Only consulted on first run —
# it cannot rotate an already-persisted key.
# FSGATE_TOKEN_SIGNING_KEY=

# Bind address. Keep 127.0.0.1 and expose only through the tunnel; use 0.0.0.0
# only for deliberate LAN exposure.
# FSGATE_HOST=127.0.0.1

# FSGATE_PORT=8420

# MCP transport mount path. Connector interop is smoothest at root.
# FSGATE_MCP_PATH=/
